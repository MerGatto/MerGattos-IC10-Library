alias buffer d0
alias heatPump d1

define PIPEANALYZER HASH("StructurePipeAnalysizer")
define TARGETTEMP 600 #Kelvin
define MINPRESSURE 20000

main:
yield
l r0 buffer PrefabHash
brne r0 PIPEANALYZER 2
s buffer On 1
# safety
l r0 buffer Pressure
bgt r0 45000 main

l r0 buffer Temperature
slt r0 r0 TARGETTEMP
l r1 buffer Pressure
slt r1 r1 MINPRESSURE
or r0 r0 r1
s heatPump On r0
j main