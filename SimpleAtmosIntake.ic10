define MAXTEMP 245

alias dVent d0
alias dAtmosSensor d1

alias vPressure r15
alias vActive r14
alias vAtmosTemp r13

s db Setting 0
start:
yield

s dVent Mode 1
# Check if Night or Daytime
l vAtmosTemp dAtmosSensor Temperature
bgt vAtmosTemp MAXTEMP Daytime

Nighttime:
s dVent On 1
j start

Daytime:
s dVent On 0
j start
